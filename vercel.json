{
  "buildCommand": "npm run build && npm --prefix server install",
  "outputDirectory": "dist",
  "framework": "vite",
  "env": [
    "VITE_API_BASE_URL",
    "MONGODB_URI",
    "SESSION_SECRET",
    "AI_PROVIDER",
    "AI_API_KEY",
    "AI_MODEL",
    "CLIENT_ORIGIN",
    "NODE_ENV"
  ],
  "envPrefix": ["VITE_", "NEXT_PUBLIC_"],
  "regions": ["iad1"],
  "functions": {
    "server/**": {
      "memory": 1024,
      "maxDuration": 30
    }
  }
}
